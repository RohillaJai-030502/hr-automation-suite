{
    "name": "HR Automation Suite",
    "image": "mcr.microsoft.com/devcontainers/python:3.12",
    "postCreateCommand": "bash .devcontainer/setup.sh",
    "forwardPorts": [5001, 5432],
    "portsAttributes": {
        "5001": {
            "label": "Flask App",
            "onAutoForward": "openBrowser"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python"
            ]
        }
    }
}